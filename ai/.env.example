# --- Database (Neon, pooled connection string) ---
# Create a dev branch in Neon and paste its pooled URL here.
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require

# --- Embeddings (OpenAI-compatible). Leave key empty for the offline fake-embedding demo. ---
EMBEDDING_API_BASE=https://api.openai.com/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# --- Reranking (Cohere). Leave empty to skip reranking (passthrough). ---
COHERE_API_KEY=
RERANK_MODEL=rerank-v3.5

# --- LLM via OpenRouter (generation + LLM-as-judge eval). Empty = dry-run. ---
OPENROUTER_API_KEY=
OPENROUTER_BASE=https://openrouter.ai/api/v1
LLM_MODEL=openai/gpt-4o-mini

# --- CORS: comma-separated frontend origins allowed to call this API ---
CORS_ORIGINS=http://localhost:3000
